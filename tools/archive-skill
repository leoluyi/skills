#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $(basename "$0") <skill-name>" >&2
  exit 1
fi

NAME="$1"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

SKILL_DIR="skills/$NAME"
EVAL_DIR="evals/$NAME"
ARCHIVE_DIR="_archive/$NAME"

if [[ ! -d "$SKILL_DIR" ]]; then
  echo "error: $SKILL_DIR does not exist" >&2
  exit 1
fi
if [[ -e "$ARCHIVE_DIR" ]]; then
  echo "error: $ARCHIVE_DIR already exists" >&2
  exit 1
fi

mkdir -p _archive
git mv "$SKILL_DIR" "$ARCHIVE_DIR"

if [[ -d "$EVAL_DIR" ]]; then
  git mv "$EVAL_DIR" "$ARCHIVE_DIR/evals"
fi

git commit -m "archive: $NAME"
echo "archived: $NAME"
